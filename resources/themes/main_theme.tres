; ─── Theme Resource ─────────────────────────────────────────────────

[resource]

; ── Button ──
Button/styles/normal = SubResource("StyleBoxFlat_btn_normal")
Button/styles/hover = SubResource("StyleBoxFlat_btn_hover")
Button/styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
Button/styles/disabled = SubResource("StyleBoxFlat_btn_disabled")
Button/styles/focus = SubResource("StyleBoxFlat_btn_focus")
Button/colors/font_color = Color(0.88, 0.88, 0.92, 1)
Button/colors/font_hover_color = Color(1, 1, 1, 1)
Button/colors/font_pressed_color = Color(0.72, 0.76, 0.86, 1)
Button/colors/font_disabled_color = Color(0.48, 0.48, 0.54, 1)
Button/colors/font_focus_color = Color(0.92, 0.92, 0.96, 1)
Button/font_sizes/font_size = 20

; ── Panel / PanelContainer ──
Panel/styles/panel = SubResource("StyleBoxFlat_panel")
PanelContainer/styles/panel = SubResource("StyleBoxFlat_panel")

; ── Label ──
Label/colors/font_color = Color(0.88, 0.88, 0.92, 1)
Label/font_sizes/font_size = 18

; ── RichTextLabel ──
RichTextLabel/colors/default_color = Color(0.88, 0.88, 0.92, 1)

; ── HSeparator ──
HSeparator/styles/separator = SubResource("StyleBoxFlat_separator")

; ── HSlider ──
HSlider/styles/grabber_area = SubResource("StyleBoxFlat_slider_grabber")
HSlider/styles/grabber_area_highlight = SubResource("StyleBoxFlat_slider_grabber_hover")
HSlider/styles/slider = SubResource("StyleBoxFlat_slider_slider")
HSlider/colors/grabber_area_color = Color(1, 1, 1, 1)
HSlider/colors/grabber_area_highlight_color = Color(1, 1, 1, 1)

; ── CheckButton ──
CheckButton/styles/normal = SubResource("StyleBoxFlat_check_track_off")
CheckButton/styles/pressed = SubResource("StyleBoxFlat_check_track_on")
CheckButton/styles/hover = SubResource("StyleBoxFlat_check_track_off")
CheckButton/styles/hover_pressed = SubResource("StyleBoxFlat_check_track_on")
CheckButton/styles/disabled = SubResource("StyleBoxFlat_check_track_off")

; ── OptionButton ──
OptionButton/styles/normal = SubResource("StyleBoxFlat_btn_normal")
OptionButton/styles/hover = SubResource("StyleBoxFlat_btn_hover")
OptionButton/styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
OptionButton/styles/disabled = SubResource("StyleBoxFlat_btn_disabled")
OptionButton/styles/focus = SubResource("StyleBoxFlat_btn_focus")

; ── PopupMenu ──
PopupMenu/styles/panel = SubResource("StyleBoxFlat_popup")
PopupMenu/colors/font_color = Color(0.88, 0.88, 0.92, 1)
PopupMenu/colors/font_hover_color = Color(1, 1, 1, 1)
PopupMenu/colors/font_disabled_color = Color(0.48, 0.48, 0.54, 1)
